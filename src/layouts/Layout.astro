---
// src/layouts/Layout.astro
// ヘッダー + フッター統合版
// ★ お問い合わせボタンを完全に削除 ★

import '../styles/global.css';
import { getLangFromUrl, useTranslations, getSwitchLangUrl, getLangDisplayName } from '../i18n/utils';
import { supportedLangs, type Lang } from '../i18n/ui.ts';
import { IMAGE_PATHS, CONTACT_INFO } from '../constants/paths.ts';

const { title } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const currentLang = lang;
---

<!doctype html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title || t('hero.title').replace('\n', ' ')}</title>

  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Playfair+Display:wght@400;700&display=swap');
  </style>

  <style>
    :root { --tw-color-primary: #4f6a5e; }
    body { font-family: 'Inter', system-ui, sans-serif; }
    h1, h2, h3 { font-family: 'Playfair Display', serif; }
    .section { scroll-margin-top: 80px; }
  </style>
</head>

<body class="bg-[#f8f5f0] text-stone-800 overflow-x-hidden antialiased">

  <!-- ==================== NAVBAR ==================== -->
  <nav id="navbar" class="sticky top-0 z-50 bg-[#f8f5f0]/80 backdrop-blur-lg border-b border-stone-200 transition-all duration-300">
    <div class="max-w-screen-2xl mx-auto px-6 md:px-10 py-4 md:py-5 flex items-center justify-between">
      
      <!-- ロゴ -->
      <div class="flex items-center gap-3">
        <a href={currentLang === 'ja' ? '/portfolio/' : `/portfolio/${currentLang}/`} class="flex items-center gap-3">
          <img src={IMAGE_PATHS.logo} alt="Logo" class="w-9 h-9 md:w-11 md:h-11 object-contain drop-shadow-sm">
          <div>
            <span class="text-2xl md:text-3xl font-medium tracking-tighter text-stone-900">
              {t('site.title')}
            </span>
            <p class="text-[9px] md:text-[10px] text-stone-500 -mt-1 tracking-[1px]">
              {t('site.subtitle')}
            </p>
          </div>
        </a>
      </div>

      <!-- デスクトップタブメニュー -->
      <slot name="nav-tabs" />

      <!-- 右側（言語切り替えのみ） -->
      <div class="flex items-center gap-3 md:gap-4">
        <!-- 言語切り替え -->
        <div class="relative hidden sm:block group">
          <button id="lang-trigger" class="flex items-center gap-2 px-5 py-2.5 text-sm font-medium border border-stone-300 hover:border-[#4f6a5e] hover:bg-white rounded-3xl transition-all">
            <img src={IMAGE_PATHS.languageIcon} alt="Language" class="w-5 h-5 object-contain">
            <span class="min-w-[72px] text-left">{getLangDisplayName(currentLang)}</span>
            <span class="text-xs opacity-70">▼</span>
          </button>

          <div class="absolute right-0 mt-1 w-52 bg-white rounded-3xl shadow-2xl border border-stone-100 py-1 overflow-hidden z-[9999] opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
            {supportedLangs.map((langCode: Lang) => (
              <a href={getSwitchLangUrl(Astro.url, langCode)} 
                 class={`block px-6 py-3.5 text-sm hover:bg-stone-100 transition-colors flex items-center justify-between mx-1 rounded-2xl ${currentLang === langCode ? 'bg-stone-50 font-medium' : ''}`}>
                <span>{getLangDisplayName(langCode)}</span>
                {currentLang === langCode && <span class="text-[#4f6a5e] text-xs">✓</span>}
              </a>
            ))}
          </div>
        </div>

        <button id="mobile-menu-button" class="md:hidden w-11 h-11 flex items-center justify-center text-3xl text-stone-700 hover:text-[#4f6a5e]">
          ☰
        </button>
      </div>
    </div>
  </nav>

  <!-- ==================== モバイルメニュー ==================== -->
  <div id="mobile-menu" class="hidden fixed inset-0 bg-black/0 backdrop-blur-2xl z-[9999] flex items-start justify-center pt-[env(safe-area-inset-top)] pb-12 overflow-y-auto">
    <div class="bg-white w-[95%] max-w-[420px] mx-auto mt-4 rounded-3xl shadow-2xl overflow-hidden border border-stone-200">
      <div class="flex justify-end px-6 py-4 border-b border-stone-100">
        <button id="mobile-close-button" class="w-11 h-11 flex items-center justify-center text-3xl text-stone-400 hover:text-stone-700">✕</button>
      </div>
      <div class="flex flex-col p-3">
        <slot name="mobile-tabs" />
        
        <!-- モバイル言語切り替え -->
        <div class="px-8 py-5 border-t border-stone-100 mt-4">
          <div class="text-xs uppercase tracking-widest text-stone-400 mb-3">{t('langSwitch')}</div>
          <div class="space-y-2">
            {supportedLangs.map((langCode: Lang) => (
              <a href={getSwitchLangUrl(Astro.url, langCode)} 
                 class={`block w-full py-4 px-6 text-center text-lg font-medium rounded-3xl transition-all active:scale-[0.97] ${currentLang === langCode ? 'bg-[#4f6a5e] text-white' : 'border border-stone-300 hover:border-[#4f6a5e] hover:bg-[#4f6a5e] hover:text-white'}`}>
                {getLangDisplayName(langCode)}
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ==================== メインコンテンツ ==================== -->
  <slot />

  <!-- ==================== FOOTER ==================== -->
  <footer id="contact" class="bg-stone-900 text-white py-20">
    <div class="max-w-screen-2xl mx-auto px-10">
      <div class="grid md:grid-cols-12 gap-12">
        <div class="md:col-span-5">
          <div class="flex items-center gap-3">
            <img src={IMAGE_PATHS.logo} alt="Logo" class="w-9 h-9 object-contain">
            <span class="text-3xl font-medium tracking-tight text-white">{t('site.title')}</span>
          </div>
          <p class="mt-8 text-stone-400 max-w-sm leading-relaxed">{t('footer.description')}</p>
          <p class="mt-12 text-xs text-stone-500">{t('footer.copyright')}</p>
        </div>

        <div class="md:col-span-4">
          <div class="font-medium mb-6 text-[#d97706] tracking-widest text-sm">{t('footer.shop')}</div>
          <div class="space-y-6">
            <a href={CONTACT_INFO.minne} target="_blank" class="group flex items-center gap-4 hover:text-[#d97706] transition-colors">
              <div class="w-12 h-12 bg-white rounded-2xl flex items-center justify-center flex-shrink-0 shadow-sm border border-stone-200 group-hover:scale-110 transition-transform">
                <img src={IMAGE_PATHS.logoMinne} alt="minne" class="w-12 h-12 object-contain">
              </div>
              <div>
                <div class="font-medium text-lg">{t('footer.minneName')}</div>
                <div class="text-xs text-stone-400">{t('footer.minneDesc')}</div>
              </div>
            </a>
            <a href={CONTACT_INFO.etsy} target="_blank" class="group flex items-center gap-4 hover:text-[#d97706] transition-colors">
              <div class="w-12 h-12 bg-white/10 rounded-2xl flex items-center justify-center flex-shrink-0 overflow-hidden group-hover:scale-110 transition-transform">
                <img src={IMAGE_PATHS.logoEtsy} alt="Etsy" class="w-12 h-12 object-contain">
              </div>
              <div>
                <div class="font-medium text-lg">{t('footer.etsyName')}</div>
                <div class="text-xs text-stone-400">{t('footer.etsyDesc')}</div>
              </div>
            </a>
          </div>
        </div>

        <div class="md:col-span-3 flex flex-col">
          <div class="font-medium mb-6 text-[#d97706] tracking-widest text-sm">{t('footer.follow')}</div>
          <div class="flex gap-4 mb-12">
            <a href={CONTACT_INFO.x} target="_blank" class="w-12 h-12 bg-white rounded-2xl flex items-center justify-center shadow-sm border border-stone-200 overflow-hidden transition-all hover:scale-110">
              <img src={IMAGE_PATHS.logoX} alt="X" class="w-7 h-7 object-contain">
            </a>
            <a href={CONTACT_INFO.instagram} target="_blank" class="w-12 h-12 bg-white rounded-2xl flex items-center justify-center overflow-hidden transition-all hover:scale-110">
              <img src={IMAGE_PATHS.logoInstagram} alt="Instagram" class="w-9 h-9 object-contain">
            </a>
          </div>

          <div>
            <div class="font-medium mb-6 text-[#d97706] tracking-widest text-sm">{t('footer.contact')}</div>
            <a href={`mailto:${CONTACT_INFO.email}`} class="w-12 h-12 bg-white rounded-2xl flex items-center justify-center overflow-hidden transition-all hover:scale-110">
              <img src={IMAGE_PATHS.mailIcon} alt="mail" class="w-12 h-12 object-contain scale-200">
            </a>
          </div>
        </div>
      </div>
    </div>
  </footer>

  <script>
    // モバイルメニュー開閉
    const mobileBtn = document.getElementById('mobile-menu-button');
    const mobileMenu = document.getElementById('mobile-menu');
    const closeBtn = document.getElementById('mobile-close-button');

    mobileBtn?.addEventListener('click', () => mobileMenu?.classList.toggle('hidden'));
    closeBtn?.addEventListener('click', () => mobileMenu?.classList.add('hidden'));

    // ナビバー影
    window.addEventListener('scroll', () => {
      const nav = document.getElementById('navbar');
      if (nav) {
        nav.classList.toggle('bg-[#f8f5f0]', window.scrollY > 30);
        nav.classList.toggle('shadow-sm', window.scrollY > 30);
      }
    });

    // ページ内リンクのスムーズスクロール（#contact以外）
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      if (anchor.getAttribute('href') === '#contact') return;

      anchor.addEventListener('click', (e) => {
        const target = document.querySelector(anchor.getAttribute('href'));
        if (target) {
          e.preventDefault();
          const navbarHeight = 80;
          const targetPosition = target.getBoundingClientRect().top + window.pageYOffset - navbarHeight;
          window.scrollTo({
            top: targetPosition,
            behavior: 'smooth'
          });
        }
      });
    });
  </script>

</body>
</html>