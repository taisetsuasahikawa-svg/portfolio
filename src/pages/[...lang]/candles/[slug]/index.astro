---
// src/pages/[...lang]/candles/[slug]/index.astro
import Layout from '../../../../layouts/Layout.astro';
import { getLangFromId, getLangFromUrl, useTranslations } from '../../../../i18n/utils';
import { CONTACT_INFO } from '../../../../constants/paths.ts';
import { getCollection, render } from 'astro:content';
import ImageSlider from '../../../../ui/ImageSlider.astro';
import TagPill from '../../../../ui/TagPill.astro';

import {
  processCandleEntry,
} from '../../../../lib/GetCandleContents.ts';

export async function getStaticPaths() {
  const allEntries = await getCollection('candles');

  const paths = allEntries.map((entry) => {
    const langFromFile = getLangFromId(entry.id);
    const slug = entry.id
      .split('/')
      .pop()
      ?.replace(/\.mdx?$/, '') || 'unknown';

    const langParam = langFromFile === 'ja' ? undefined : langFromFile;

    return {
      params: {
        lang: langParam,
        slug,
      },
      props: {
        entry,
        lang: langFromFile,
      },
    };
  });

  return paths;
}

const { entry } = Astro.props;
const currentLang = getLangFromUrl(Astro.url);
const t = useTranslations(currentLang);

const candle = processCandleEntry(entry, currentLang);
const { Content } = await render(entry);
---

<Layout title={`${candle.title} | ${t('site.title')}`}>
  <div class="max-w-screen-2xl mx-auto px-6 md:px-10 py-12 bg-[#f8f5f0]">
    <a
      href={currentLang === 'ja' ? '/portfolio/candles/' : `/portfolio/${currentLang}/candles/`}
      class="inline-flex items-center gap-2 text-[#4f6a5e] hover:text-stone-900 mb-8 font-medium transition-colors"
    >
      ← {t('candle.goToCollection')}
    </a>

    <div class="grid lg:grid-cols-12 gap-12 lg:gap-16">
      <div class="lg:col-span-5 space-y-10">
        <h1 class="text-5xl md:text-6xl font-medium tracking-tight text-stone-900 leading-none">
          {candle.title}
        </h1>

        <p class="text-xl text-stone-600 leading-relaxed">{candle.description}</p>
        {candle.desc1 && <p class="text-xl text-stone-600 leading-relaxed">{candle.desc1}</p>}
        {candle.desc2 && <p class="text-xl text-stone-600 leading-relaxed">{candle.desc2}</p>}

        <div class="lg:hidden">
          <ImageSlider images={candle.images} title={candle.title} lang={currentLang} />
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-8 text-sm border-t border-stone-200 pt-8">
          {candle.burnTime && (
            <div>
              <div class="text-stone-500 mb-1">{t('candle.detail.burnTime')}</div>
              <div class="font-medium text-lg">{candle.burnTime}</div>
            </div>
          )}
          {candle.size && (
            <div>
              <div class="text-stone-500 mb-1">{t('candle.detail.size')}</div>
              <div class="font-medium text-lg">{candle.size}</div>
            </div>
          )}
        </div>

        <div class="flex flex-wrap gap-2">
          {candle.tags?.map((tag: string) => (
            <TagPill tag={tag} lang={currentLang} />
          ))}
        </div>

        <div class="text-xl text-stone-600 leading-relaxed">
          <Content />
        </div>
      </div>

      <div class="hidden lg:block lg:col-span-7">
        <ImageSlider images={candle.images} title={candle.title} lang={currentLang} />

        <div class="pt-4 space-y-4">
          <a
            href={CONTACT_INFO.minne}
            target="_blank"
            class="block w-full py-6 text-center bg-[#4f6a5e] hover:bg-[#3f554a] text-white font-medium rounded-3xl transition-all text-lg"
          >
            {t('common.viewOnMinne')}
          </a>
          <a
            href={CONTACT_INFO.etsy}
            target="_blank"
            class="block w-full py-6 text-center border-2 border-[#4f6a5e] text-[#4f6a5e] hover:bg-[#4f6a5e] hover:text-white font-medium rounded-3xl transition-all text-lg"
          >
            {t('common.viewOnEtsy')}
          </a>
        </div>
      </div>
    </div>
  </div>
</Layout>
