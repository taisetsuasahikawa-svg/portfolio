---
// src/pages/[...lang]/candles/[slug]/index.astro
// 個別作品ページ

import Layout from '../../../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations } from '../../../../i18n/utils';
import { supportedLangs } from '../../../../i18n/ui.ts';
import { getCollection, render } from 'astro:content';
import ImageSlider from '../../../../ui/ImageSlider.astro';

export async function getStaticPaths() {
  const allEntries = await getCollection('candles');

  return allEntries.flatMap((entry) => 
    supportedLangs.map((lang) => ({
      params: {
        lang: lang === 'ja' ? undefined : lang,
        slug: entry.data.slug || entry.id,
      },
      props: { 
        entry, 
        lang 
      },
    }))
  );
}

const { entry, lang: propLang } = Astro.props;
const currentLang = propLang || getLangFromUrl(Astro.url);
const t = useTranslations(currentLang);

const data = entry.data;
const { Content } = await render(entry);
---

<Layout title={`${data.title[currentLang]} | ${t('site.title')}`}>

  <div class="max-w-screen-2xl mx-auto px-6 md:px-10 py-12 bg-[#f8f5f0]">

    <!-- 戻るリンク -->
    <a 
      href={currentLang === 'ja' ? '/portfolio/candles/' : `/portfolio/${currentLang}/candles/`}
      class="inline-flex items-center gap-2 text-[#4f6a5e] hover:text-stone-900 mb-8 font-medium transition-colors">
      ← {t('candle.goToCollection')}
    </a>

    <div class="grid lg:grid-cols-12 gap-12 lg:gap-16">

      <!-- 左カラム：情報パネル -->
      <div class="lg:col-span-5 space-y-10">

        <!-- タイトル -->
        <h1 class="text-5xl md:text-6xl font-medium tracking-tight text-stone-900 leading-none">
          {data.title[currentLang]}
        </h1>

        <!-- 説明 -->
        <p class="text-xl text-stone-600 leading-relaxed">
          {data.description[currentLang]}
        </p>

        <!-- ★★★ 画像スライダー（タイトル・説明の直後） ★★★ -->
        <div class="lg:hidden">
          <ImageSlider 
            images={data.images || []}
            title={data.title}
            lang={currentLang}
          />
        </div>

        <!-- スペック -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-8 text-sm border-t border-stone-200 pt-8">
          {data.burnTime && (
            <div>
              <div class="text-stone-500 mb-1">{t('candle.detail.burnTime') || '燃焼時間'}</div>
              <div class="font-medium text-lg">{data.burnTime[currentLang]}</div>
            </div>
          )}
          {data.size && (
            <div>
              <div class="text-stone-500 mb-1">{t('candle.detail.size') || 'サイズ'}</div>
              <div class="font-medium text-lg">{data.size[currentLang]}</div>
            </div>
          )}
        </div>

        <!-- タグ -->
        <div class="flex flex-wrap gap-2">
          {data.tags?.map((tag: string) => (
            <span class="px-5 py-2 bg-[#4f6a5e]/10 text-[#4f6a5e] rounded-3xl text-sm font-medium">
              #{t(`candleTag.${tag}`) || tag}
            </span>
          ))}
        </div>

        <!-- 購入ボタン -->
        <div class="pt-4 space-y-4">
          <a href="https://minne.com/@tcc2024/" target="_blank" 
             class="block w-full py-6 text-center bg-[#4f6a5e] hover:bg-[#3f554a] text-white font-medium rounded-3xl transition-all text-lg">
            {t('common.viewOnMinne')}
          </a>
          <a href="https://www.etsy.com/shop/MineralArtCandlesJP/" target="_blank" 
             class="block w-full py-6 text-center border-2 border-[#4f6a5e] text-[#4f6a5e] hover:bg-[#4f6a5e] hover:text-white font-medium rounded-3xl transition-all text-lg">
            {t('common.viewOnEtsy')}
          </a>
        </div>
      </div>

      <!-- 右カラム：画像スライダー（デスクトップのみ表示） -->
      <div class="hidden lg:block lg:col-span-7">
        <ImageSlider 
          images={data.images || []}
          title={data.title}
          lang={currentLang}
        />
      </div>

    </div>

    <!-- MDX 本文 -->
    <div class="max-w-3xl mx-auto mt-20 prose prose-stone prose-headings:font-medium">
      <Content />
    </div>

  </div>
</Layout>