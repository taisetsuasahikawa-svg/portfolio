---
// src/pages/[...lang]/thanks.astro
// 修正版：trailingSlash: 'always' + Astro.url の挙動を厳密に扱い、言語切替を確実に維持

import Layout from '../../layouts/Layout.astro';
import { supportedLangs, type Lang } from '../../i18n/ui.ts';
import { useTranslations, getSwitchLangUrl, getLangDisplayName } from '../../i18n/utils';
import LanguageSwitcher from '../../ui/LanguageSwitcher.astro';

export async function getStaticPaths() {
  return supportedLangs.map((lang: Lang) => ({
    params: { 
      lang: lang === 'ja' ? undefined : lang 
    },
    props: { lang }
  }));
}

const { lang: propLang } = Astro.props;
const currentLang = (propLang || 'ja') as Lang;
const t = useTranslations(currentLang);

// 現在のURLを正規化（trailingSlash対策）
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/portfolio';
---

<Layout title={t('care.title')}>

  <div class="max-w-screen-2xl mx-auto px-6 md:px-10 py-20 bg-[#f8f5f0]">

    <!-- ヘッダー＆言語切替 -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 mb-16">
      <div>
        <h1 class="text-5xl md:text-6xl font-medium tracking-tight text-stone-900">
          {t('care.title')}
        </h1>
        <p class="mt-3 text-stone-600 text-lg">
          {t('care.subtitle')}
        </p>
      </div>

      <!-- 言語切替（修正済み） -->
      <LanguageSwitcher 
        currentUrl={Astro.url} 
        currentLang={currentLang} 
      />
    </div>

    <div class="max-w-3xl mx-auto space-y-20">

      <section>
        <h2 class="text-3xl font-medium mb-8 border-l-4 border-[#4f6a5e] pl-6">
          {t('care.safetyTitle')}
        </h2>
        <ul class="space-y-6 text-lg text-stone-700">
          {t('care.safetyList').map((item: string, i: number) => (
            <li key={i} class="flex gap-4">
              <span class="text-[#4f6a5e] font-medium text-2xl leading-none mt-1">•</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </section>

      <section>
        <h2 class="text-3xl font-medium mb-8 border-l-4 border-[#4f6a5e] pl-6">
          {t('care.careTitle')}
        </h2>
        <ul class="space-y-6 text-lg text-stone-700">
          {t('care.careList').map((item: string, i: number) => (
            <li key={i} class="flex gap-4">
              <span class="text-[#4f6a5e] font-medium text-2xl leading-none mt-1">•</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </section>

      <div class="bg-white border border-stone-200 rounded-3xl p-10 text-center">
        <p class="text-xl text-stone-700 leading-relaxed">
          {t('care.contact')}
        </p>
        <a 
          href="mailto:taisetsu.asahikawa@gmail.com"
          class="mt-8 inline-block px-10 py-4 bg-[#4f6a5e] hover:bg-[#3f554a] text-white font-medium rounded-3xl transition-all active:scale-95">
          taisetsu.asahikawa@gmail.com
        </a>
      </div>

    </div>

    <!-- 戻るボタン -->
    <div class="mt-20 text-center">
      <a 
        href={currentLang === 'ja' ? '/portfolio/' : `/portfolio/${currentLang}/`}
        class="inline-flex items-center gap-3 text-[#4f6a5e] hover:text-stone-900 font-medium text-lg transition-colors">
        ← {t('care.backToHome')}
      </a>
    </div>
  </div>

</Layout>