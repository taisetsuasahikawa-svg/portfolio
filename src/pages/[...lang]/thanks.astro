---
// src/pages/[...lang]/thanks.astro
import Layout from '../../layouts/Layout.astro';
import { supportedLangs, type Lang, ui } from '../../i18n/ui.ts';
import { useTranslations } from '../../i18n/utils';
import { IMAGE_PATHS, CONTACT_INFO } from '../../constants/paths.ts';
import { Image } from 'astro:assets';

export async function getStaticPaths() {
  return supportedLangs.map((lang: Lang) => ({
    params: { lang: lang === 'ja' ? undefined : lang },
    props: { lang },
  }));
}

const { lang: propLang } = Astro.props;
const currentLang = (propLang || 'ja') as Lang;
const t = useTranslations(currentLang);

const safetyItems = ui.care.items.safety;
---

<Layout title={t('care.title')}>
  <div class="max-w-screen-2xl mx-auto px-6 md:px-10 py-20 bg-[#f8f5f0]">
    <a
      href={currentLang === 'ja' ? '/portfolio/candles/' : `/portfolio/${currentLang}/candles/`}
      class="inline-flex items-center gap-2 text-[#4f6a5e] hover:text-stone-900 mb-8 font-medium transition-colors"
    >
      ← {t('candle.goToCollection')}
    </a>

    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 mb-16">
      <div>
        <h1 class="text-5xl md:text-6xl font-medium tracking-tight text-stone-900">
          {t('care.title')}
        </h1>
        <p class="mt-3 text-stone-600 text-lg">
          {t('care.subtitle')}
        </p>
      </div>
    </div>

    <div class="max-w-3xl mx-auto mb-16 text-center">
      <p class="text-xl text-stone-700 leading-relaxed" set:html={t('care.intro')} />
    </div>

    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl font-medium mb-10 border-l-4 border-[#4f6a5e] pl-6">
        {t('care.safetyTitle')}
      </h2>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {safetyItems.map((item: any, index: number) => {
          const text = item[currentLang] || item.ja || '';
          const imageKey = `safety${index + 1}` as const;
          const imageSrc = IMAGE_PATHS.care[imageKey];

          return (
            <div
              key={item.id || `safety-${index}`}
              class="bg-white border border-stone-200 rounded-3xl overflow-hidden hover:border-[#4f6a5e] hover:shadow-xl transition-all group"
            >
              <div class="relative h-56 bg-stone-100 flex items-center justify-center overflow-hidden">
                {imageSrc ? (
                  <Image
                    src={imageSrc}
                    alt={`Safety guideline ${index + 1}`}
                    width={600}
                    height={400}
                    class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                    loading={index < 3 ? 'eager' : 'lazy'}
                  />
                ) : (
                  <div class="w-full h-full flex flex-col items-center justify-center bg-gradient-to-br from-[#4f6a5e]/10 to-stone-200 text-stone-500 text-center px-6">
                    <span class="text-6xl mb-3">🕯️</span>
                    <p class="text-base font-medium">{t('common.emptyMessage')}</p>
                  </div>
                )}

                <div class="absolute top-4 right-4 bg-white/95 text-[#4f6a5e] font-semibold text-2xl w-10 h-10 rounded-2xl flex items-center justify-center shadow">
                  {index + 1}
                </div>
              </div>

              <div class="p-8 pt-6">
                <p class="text-[17px] leading-relaxed text-stone-700">
                  {text}
                </p>
              </div>
            </div>
          );
        })}
      </div>

      <div class="mt-16 text-center">
        <p class="text-stone-600 mb-6">{t('care.contact')}</p>
        <a
          href={`mailto:${CONTACT_INFO.email}`}
          class="block w-full max-w-xs mx-auto px-8 py-4 bg-[#4f6a5e] hover:bg-[#3f554a] text-white font-medium rounded-3xl transition-all active:scale-95 text-base break-all"
        >
          {CONTACT_INFO.email}
        </a>
      </div>
    </div>
  </div>
</Layout>
