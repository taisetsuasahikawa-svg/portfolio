---
// src/pages/[...lang]/index.astro
// 多言語対応・GitHub Pages完全対応・言語追加が ui.ts 1箇所だけで済む最終版
// ヘッダー・フッターは Layout.astro に統合済み

import { supportedLangs, type Lang } from '../../i18n/ui.ts';
import Layout from '../../layouts/Layout.astro';

import HeroSection from '../../components/HeroSection.astro';
import NewsSection from '../../components/NewsSection.astro';
import CandleSection from '../../components/CandleSection.astro';
import AppSection from '../../components/AppSection.astro';
import MaterialsSection from '../../components/MaterialsSection.astro';
import EventsSection from '../../components/EventsSection.astro';

import { useTranslations } from '../../i18n/utils';

export async function getStaticPaths() {
  return supportedLangs.map((lang: Lang) => ({
    params: { 
      lang: lang === 'ja' ? undefined : lang 
    },
    props: { lang }
  }));
}

const { lang: propLang } = Astro.props;
const currentLang = propLang;
const t = useTranslations(currentLang);
---

<Layout title={t('site.title')}>

  <!-- ==================== デスクトップ用タブメニュー (スロット) ==================== -->
  <div slot="nav-tabs" class="hidden md:flex items-center gap-1 bg-white rounded-3xl p-1 shadow-sm border border-stone-100" id="tab-buttons">
    <button data-tab="0" class="tab-button px-7 py-3 text-base font-medium rounded-3xl transition-all active bg-[#4f6a5e] text-white">
      {t('nav.home')}
    </button>
    <button data-tab="1" class="tab-button px-7 py-3 text-base font-medium rounded-3xl transition-all">
      {t('nav.candles')}
    </button>
    <button data-tab="2" class="tab-button px-7 py-3 text-base font-medium rounded-3xl transition-all">
      {t('nav.apps')}
    </button>
    <button data-tab="3" class="tab-button px-7 py-3 text-base font-medium rounded-3xl transition-all">
      {t('nav.materials')}
    </button>
  </div>

  <!-- ==================== モバイル用タブメニュー (スロット) ==================== -->
  <div slot="mobile-tabs" class="flex flex-col p-3">
    <button data-tab="0" class="mobile-tab-button w-full text-left px-8 py-5 text-[21px] font-medium rounded-2xl hover:bg-stone-100 active:bg-stone-200 transition-all">
      {t('nav.home')}
    </button>
    <button data-tab="1" class="mobile-tab-button w-full text-left px-8 py-5 text-[21px] font-medium rounded-2xl hover:bg-stone-100 active:bg-stone-200 transition-all">
      {t('nav.candles')}
    </button>
    <button data-tab="2" class="mobile-tab-button w-full text-left px-8 py-5 text-[21px] font-medium rounded-2xl hover:bg-stone-100 active:bg-stone-200 transition-all">
      {t('nav.apps')}
    </button>
    <button data-tab="3" class="mobile-tab-button w-full text-left px-8 py-5 text-[21px] font-medium rounded-2xl hover:bg-stone-100 active:bg-stone-200 transition-all">
      {t('nav.materials')}
    </button>
  </div>

  <!-- ==================== メインコンテンツ ==================== -->
  <div class="max-w-screen-2xl mx-auto px-6 md:px-10" id="tab-content">
    <div id="tab-panel-0" class="tab-panel">
      <HeroSection />
      <NewsSection />
      <EventsSection />
    </div>

    <div id="tab-panel-1" class="tab-panel hidden">
      <CandleSection />
    </div>

    <div id="tab-panel-2" class="tab-panel hidden">
      <AppSection />
    </div>

    <div id="tab-panel-3" class="tab-panel hidden">
      <MaterialsSection />
    </div>
  </div>

  <!-- タブ切り替え用スクリプト -->
  <script>
    // タブ定義
    const tabConfig = {
      0: { name: 'home', label: 'HOME' },
      1: { name: 'candles', label: 'Candles' },
      2: { name: 'apps', label: 'Apps' },
      3: { name: 'materials', label: 'Materials' }
    } as const;

    function getTabIndexFromSlug(slug: string | null): number {
      if (!slug) return 0;
      const entry = Object.entries(tabConfig).find(([_, config]) => config.name === slug);
      return entry ? parseInt(entry[0]) : 0;
    }

    function getSlugFromTabIndex(index: number): string {
      return tabConfig[index as keyof typeof tabConfig]?.name || 'home';
    }

    function switchTab(tabIndex: number, pushState: boolean = true) {
      const slug = getSlugFromTabIndex(tabIndex);

      // パネル切り替え
      document.querySelectorAll('.tab-panel').forEach((panel, i) => {
        panel.classList.toggle('hidden', i !== tabIndex);
      });

      // ボタンアクティブ状態
      document.querySelectorAll('.tab-button, .mobile-tab-button').forEach(btn => {
        const button = btn as HTMLButtonElement;
        const btnIndex = parseInt(button.getAttribute('data-tab') || '0');
        button.classList.toggle('active', btnIndex === tabIndex);
        button.classList.toggle('bg-[#4f6a5e]', btnIndex === tabIndex);
        button.classList.toggle('text-white', btnIndex === tabIndex);
      });

      // URLにタブ名を反映
      if (pushState) {
        const url = new URL(window.location.href);
        if (slug === 'home') {
          url.searchParams.delete('tab');
        } else {
          url.searchParams.set('tab', slug);
        }
        window.history.pushState({ tab: tabIndex, slug }, '', url.toString());
      }

      // スムーズスクロール
      const navbarHeight = 80;
      setTimeout(() => {
        const target = document.getElementById(`tab-panel-${tabIndex}`);
        if (target) {
          const rect = target.getBoundingClientRect();
          window.scrollTo({
            top: window.pageYOffset + rect.top - navbarHeight,
            behavior: 'smooth'
          });
        }
      }, 80);
    }

    // ブラウザバック・フォワード対応
    function handlePopState(e: PopStateEvent) {
      let tabIndex = 0;
      if (e.state && typeof e.state.tab === 'number') {
        tabIndex = e.state.tab;
      } else {
        const urlParams = new URLSearchParams(window.location.search);
        const slug = urlParams.get('tab');
        tabIndex = getTabIndexFromSlug(slug);
      }
      switchTab(tabIndex, false);
    }

    // 初期化
    function initTabs() {
      // デスクトップタブ
      document.querySelectorAll('.tab-button').forEach(btn => {
        btn.addEventListener('click', () => {
          const index = parseInt((btn as HTMLButtonElement).getAttribute('data-tab') || '0');
          switchTab(index);
        });
      });

      // モバイルタブ
      document.querySelectorAll('.mobile-tab-button').forEach(btn => {
        btn.addEventListener('click', () => {
          const index = parseInt((btn as HTMLButtonElement).getAttribute('data-tab') || '0');
          switchTab(index);
          document.getElementById('mobile-menu')?.classList.add('hidden');
        });
      });

      // 初期タブ（言語切り替え後は常にHOMEに戻る）
      const urlParams = new URLSearchParams(window.location.search);
      const initialSlug = urlParams.get('tab');
      const initialTab = getTabIndexFromSlug(initialSlug);

      switchTab(initialTab, false);

      // popstate登録
      window.addEventListener('popstate', handlePopState);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initTabs);
    } else {
      initTabs();
    }
  </script>

</Layout>