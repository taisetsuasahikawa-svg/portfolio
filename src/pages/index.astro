---
/*
  src/pages/index.astro
  更新：2026年4月 モバイル版ボタン・テキストサイズ最適化
  スマホで見づらかったボタン・メニューをコンパクトに調整
*/

import Layout from '../layouts/Layout.astro';
import HeroSection from '../components/HeroSection.astro';
import NewsSection from '../components/NewsSection.astro';
import CandleSection from '../components/CandleSection.astro';
import AppSection from '../components/AppSection.astro';
import MaterialsSection from '../components/MaterialsSection.astro';
import EventsSection from '../components/EventsSection.astro';

const title = '大雪クラフターズキャラバン | キャンドル制作 × アプリ開発';
---

<Layout title={title}>
  <!-- ==================== 改善版 NAVBAR ==================== -->
  <nav id="navbar" 
       class="sticky top-0 z-50 bg-[#f8f5f0]/80 backdrop-blur-lg border-b border-stone-200 transition-all duration-300">
    <div class="max-w-screen-2xl mx-auto px-6 md:px-10 py-4 md:py-5 flex items-center justify-between">
      
      <!-- ロゴ部分 -->
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 md:w-9 md:h-9 bg-[#4f6a5e] rounded-2xl flex items-center justify-center text-white text-2xl md:text-3xl shadow-sm">🕯️</div>
        <div>
          <a href="/" class="text-2xl md:text-3xl font-medium tracking-tighter text-stone-900">大雪クラフターズキャラバン</a>
          <p class="text-[9px] md:text-[10px] text-stone-500 -mt-1 tracking-[1px]">CANDLE × APP × MATERIALS</p>
        </div>
      </div>
      
      <!-- デスクトップ用タブメニュー -->
      <div class="hidden md:flex items-center gap-1 bg-white rounded-3xl p-1 shadow-sm border border-stone-100" id="tab-buttons">
        <button data-tab="0" class="tab-button px-7 py-3 text-base font-medium rounded-3xl transition-all active bg-[#4f6a5e] text-white">
          HOME
        </button>
        <button data-tab="1" class="tab-button px-7 py-3 text-base font-medium rounded-3xl transition-all">
          キャンドル
        </button>
        <button data-tab="2" class="tab-button px-7 py-3 text-base font-medium rounded-3xl transition-all">
          アプリ
        </button>
        <button data-tab="3" class="tab-button px-7 py-3 text-base font-medium rounded-3xl transition-all">
          ハンドメイド資材
        </button>
      </div>
      
      <!-- 右側：お問い合わせ + モバイルメニュー -->
      <div class="flex items-center gap-3 md:gap-4">
        <a href="#contact" 
           class="hidden sm:block px-6 py-2.5 text-sm font-medium border border-stone-300 hover:border-[#4f6a5e] hover:bg-[#4f6a5e] hover:text-white rounded-3xl transition-all">
          お問い合わせ
        </a>
        
        <!-- ハンバーガーボタン（少しコンパクトに） -->
        <button id="mobile-menu-button" 
                class="md:hidden w-10 h-10 flex items-center justify-center text-2xl text-stone-700 hover:text-[#4f6a5e] transition-colors">
          ☰
        </button>
      </div>
    </div>

    <!-- モバイルメニュー（ボタンサイズ・余白を最適化） -->
    <div id="mobile-menu" class="hidden md:hidden fixed inset-0 bg-white z-40 pt-16 px-6 overflow-y-auto">
      <div class="flex flex-col gap-1">
        <button data-tab="0" 
                class="mobile-tab-button w-full text-left px-5 py-4 text-lg font-medium rounded-3xl hover:bg-stone-100 active:bg-stone-200 transition-all">
          HOME
        </button>
        <button data-tab="1" 
                class="mobile-tab-button w-full text-left px-5 py-4 text-lg font-medium rounded-3xl hover:bg-stone-100 active:bg-stone-200 transition-all">
          キャンドル作品
        </button>
        <button data-tab="2" 
                class="mobile-tab-button w-full text-left px-5 py-4 text-lg font-medium rounded-3xl hover:bg-stone-100 active:bg-stone-200 transition-all">
          アプリ開発
        </button>
        <button data-tab="3" 
                class="mobile-tab-button w-full text-left px-5 py-4 text-lg font-medium rounded-3xl hover:bg-stone-100 active:bg-stone-200 transition-all">
          ハンドメイド資材
        </button>
        
        <div class="mt-10 pt-8 border-t border-stone-200">
          <a href="#contact" 
             class="block w-full py-4 text-center text-base font-medium border-2 border-[#4f6a5e] text-[#4f6a5e] rounded-3xl hover:bg-[#4f6a5e] hover:text-white transition-all">
            お問い合わせ
          </a>
        </div>
      </div>
      
      <!-- 閉じるボタン -->
      <button id="mobile-close-button" 
              class="absolute top-6 right-6 text-3xl text-stone-400 hover:text-stone-700">
        ✕
      </button>
    </div>
  </nav>

  <!-- ==================== メインコンテンツ（変更なし） ==================== -->
  <div class="max-w-screen-2xl mx-auto px-6 md:px-10" id="tab-content">

    <!-- TAB 0: HOME -->
    <div id="tab-panel-0" class="tab-panel">
      <HeroSection client:load />
      <NewsSection client:load />
      <EventsSection client:load />
    </div>

    <!-- TAB 1: キャンドル -->
    <div id="tab-panel-1" class="tab-panel hidden">
      <div class="pt-16 md:pt-20 pb-10">
        <h2 class="text-5xl md:text-6xl font-medium tracking-tight text-stone-800 mb-4">キャンドル作品一覧</h2>
        <p class="text-stone-600 text-lg md:text-xl">自然の鉱物をイメージしたオリジナルキャンドル</p>
      </div>
      <CandleSection client:load />
    </div>

    <!-- TAB 2: アプリ -->
    <div id="tab-panel-2" class="tab-panel hidden">
      <div class="pt-16 md:pt-20 pb-10">
        <h2 class="text-5xl md:text-6xl font-medium tracking-tight text-stone-800">アプリ開発</h2>
      </div>
      <AppSection client:load />
    </div>

    <!-- TAB 3: ハンドメイド資材 -->
    <div id="tab-panel-3" class="tab-panel hidden">
      <div class="pt-16 md:pt-20 pb-10">
        <h2 class="text-5xl md:text-6xl font-medium tracking-tight text-stone-800">ハンドメイド資材販売</h2>
      </div>
      <MaterialsSection client:load />
    </div>

  </div>

  <!-- FOOTER（変更なし） -->
  <footer id="contact" class="bg-stone-900 text-white py-20">
    <!-- 既存のフッター内容はそのまま -->
    <div class="max-w-screen-2xl mx-auto px-10 grid md:grid-cols-12 gap-12">
      <div class="md:col-span-5">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 bg-white text-stone-900 rounded-2xl flex items-center justify-center text-2xl">🕯️</div>
          <span class="text-3xl font-medium">大雪クラフターズキャラバン</span>
        </div>
        <p class="mt-8 text-stone-400 max-w-sm">
          自然の美しさをキャンドルに。<br>
          IT技術を活用したキャンドル作りを模索しています
        </p>
        <p class="mt-auto text-xs text-stone-500 pt-16">© 2026 Taisetsu Crafter's Caravan</p>
      </div>
      
      <div class="md:col-span-7 grid grid-cols-3 gap-8 text-sm">
        <div>
          <div class="font-medium mb-4">リンク</div>
          <a href="#" onclick="switchTab(0)" class="block py-1 hover:text-[#d97706]">HOME</a>
          <a href="#" onclick="switchTab(1)" class="block py-1 hover:text-[#d97706]">キャンドル作品</a>
          <a href="#" onclick="switchTab(2)" class="block py-1 hover:text-[#d97706]">アプリ開発</a>
          <a href="#" onclick="switchTab(3)" class="block py-1 hover:text-[#d97706]">ハンドメイド資材</a>
        </div>
        <div>
          <div class="font-medium mb-4">ショップ</div>
          <a href="https://minne.com/@tcc2024" target="_blank" class="block py-1 hover:text-[#d97706]">minne</a>
          <a href="https://www.etsy.com/shop/MineralArtCandlesJP" target="_blank" class="block py-1 hover:text-[#d97706]">Etsy</a>
        </div>
        <div class="bg-white/10 p-8 rounded-3xl">
          <p class="text-xs mb-6">ご依頼・コラボはこちら</p>
          <input type="email" placeholder="メールアドレス" class="w-full bg-transparent border-b border-white/30 py-3 text-sm focus:outline-none">
          <button class="mt-8 w-full py-4 bg-white text-stone-900 font-medium rounded-3xl text-sm">送信</button>
        </div>
      </div>
    </div>
  </footer>

  <!-- ==================== スクリプト（モバイルメニュー制御はそのまま） ==================== -->
  <script>
    function switchTab(tabIndex) {
      document.querySelectorAll('.tab-panel').forEach(panel => panel.classList.add('hidden'));
      const activePanel = document.getElementById(`tab-panel-${tabIndex}`);
      if (activePanel) activePanel.classList.remove('hidden');

      document.querySelectorAll('.tab-button, .mobile-tab-button').forEach(btn => {
        btn.classList.remove('active', 'bg-[#4f6a5e]', 'text-white');
        if (parseInt(btn.getAttribute('data-tab') || '0') === tabIndex) {
          btn.classList.add('active', 'bg-[#4f6a5e]', 'text-white');
        }
      });

      const navbarHeight = 75;
      setTimeout(() => {
        const target = document.getElementById(`tab-panel-${tabIndex}`);
        if (target) {
          const rect = target.getBoundingClientRect();
          window.scrollTo({ top: window.pageYOffset + rect.top - navbarHeight, behavior: 'smooth' });
        }
      }, 80);
    }

    document.addEventListener('DOMContentLoaded', () => {
      // デスクトップタブ
      document.querySelectorAll('.tab-button').forEach(btn => {
        btn.addEventListener('click', () => switchTab(parseInt(btn.dataset.tab)));
      });

      // モバイルタブ
      document.querySelectorAll('.mobile-tab-button').forEach(btn => {
        btn.addEventListener('click', () => {
          switchTab(parseInt(btn.dataset.tab));
          document.getElementById('mobile-menu').classList.add('hidden');
          document.getElementById('mobile-menu-button').textContent = '☰';
        });
      });

      // モバイルメニュー開閉
      const mobileBtn = document.getElementById('mobile-menu-button');
      const mobileMenu = document.getElementById('mobile-menu');
      const closeBtn = document.getElementById('mobile-close-button');

      mobileBtn.addEventListener('click', () => {
        const isHidden = mobileMenu.classList.toggle('hidden');
        mobileBtn.textContent = isHidden ? '☰' : '✕';
      });

      closeBtn.addEventListener('click', () => {
        mobileMenu.classList.add('hidden');
        mobileBtn.textContent = '☰';
      });

      switchTab(0); // 初期表示
    });

    // スクロール時のナビ背景調整
    window.addEventListener('scroll', () => {
      const nav = document.getElementById('navbar');
      if (window.scrollY > 30) {
        nav.classList.add('bg-[#f8f5f0]', 'shadow-sm');
      } else {
        nav.classList.remove('bg-[#f8f5f0]', 'shadow-sm');
      }
    });
  </script>
</Layout>