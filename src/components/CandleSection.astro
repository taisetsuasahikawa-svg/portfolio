---
// src/components/CandleSection.astro
import WorkCard from '../ui/WorkCard.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { candlesRaw } from '../data/candles.ts';
import { IMAGE_PATHS } from '../constants/paths.ts';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const getCandleImage = (id: string): string => {
  return IMAGE_PATHS.candles[id as CandleImageKey] || 
         `${import.meta.env.BASE_URL}images/candles/placeholder.jpg`; // フォールバック
};

const candles = candlesRaw.map((item) => ({
  ...item,
  image: getCandleImage(item.id),           // ← idから画像パスを取得
  title: item.title[lang],
  description: item.description[lang],
  translatedTags: item.tags.map(tagKey => ({
    key: tagKey,
    label: t(`candleTag.${tagKey}`)
  }))
}));

// 全てのユニークなタグをサーバー側で集める（フィルター用）
const allTagObjects = [...new Set(
  candlesRaw.flatMap(item => item.tags)
)].map(tagKey => ({
  key: tagKey,
  label: t(`candleTag.${tagKey}`)
}));
---

<div id="candles" class="section py-28 bg-white" data-island>
  <div class="max-w-screen-2xl mx-auto px-10">

    <!-- 取扱説明書リンク -->
    <div class="mb-10 flex justify-center md:justify-end">
      <a 
        href={lang === 'en' ? "/portfolio/thanks?lang=en" : "/portfolio/thanks"}
        class="group inline-flex items-center gap-3 px-8 py-4 bg-white border-2 border-[#4f6a5e] 
               rounded-3xl hover:bg-[#4f6a5e] hover:text-white hover:border-[#4f6a5e] 
               transition-all duration-300 text-[#4f6a5e] font-medium text-lg shadow-sm">
        <span>{t('candle.careTitle')}</span>
        <span class="group-hover:translate-x-1 transition-transform">→</span>
      </a>
    </div>

    <!-- ヘッダー -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-baseline gap-6 mb-12">
      <div>
        <h2 class="text-5xl font-medium tracking-tight text-stone-800">
          {t('candle.section.title')}
        </h2>
        <p class="text-stone-600 mt-2">
          {t('candle.section.desc')}
        </p>
      </div>
      
      <!-- 外部ショップリンク -->
      <div class="flex flex-col gap-3">
        <a href="https://minne.com/@tcc2024" target="_blank" class="text-[#4f6a5e] hover:underline text-lg inline-flex items-center gap-2">
          {t('common.viewOnMinne')}
        </a>
        <a href="https://www.etsy.com/shop/MineralArtCandlesJP" target="_blank" class="text-[#4f6a5e] hover:underline text-lg inline-flex items-center gap-2">
          {t('common.viewOnEtsy')}
        </a>
      </div>
    </div>

    <!-- 検索＆フィルターエリア -->
    <div class="mb-12 flex flex-col md:flex-row gap-4 items-center">
      <div class="relative flex-1 max-w-md">
        <form id="search-form" class="relative">
          <input 
            id="search-input"
            type="text" 
            placeholder={t('candle.searchPlaceholder')}
            class="w-full px-6 py-4 bg-white border border-stone-200 rounded-3xl focus:outline-none focus:border-[#4f6a5e] text-base placeholder:text-stone-400 pr-14"
          >
          <button 
            type="submit"
            id="search-button"
            class="absolute right-2 top-1/2 -translate-y-1/2 w-10 h-10 flex items-center justify-center text-stone-400 hover:text-[#4f6a5e] hover:bg-stone-100 active:bg-stone-200 rounded-2xl transition-all">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 01-14 0 7 7 0 0114 0z" />
            </svg>
          </button>
        </form>
      </div>

      <!-- タグフィルター（サーバー側で生成） -->
      <div class="flex-1">
        <div id="tag-filters" class="flex flex-wrap gap-2">
          {allTagObjects.map(tag => (
            <button 
              data-tag={tag.key}
              class="tag-btn px-5 py-2 text-sm font-medium rounded-3xl border border-stone-200 hover:border-[#4f6a5e] transition-all active:scale-95">
              #{tag.label}
            </button>
          ))}
        </div>
      </div>

      <button id="clear-filters" 
              class="px-6 py-3 text-sm font-medium border border-stone-300 hover:border-[#4f6a5e] rounded-3xl transition-colors whitespace-nowrap">
        {t('common.clearFilters')}
      </button>
    </div>

    <!-- 作品グリッド -->
    <div id="candle-grid" class="grid md:grid-cols-3 gap-8">
      {candles.map((candle) => (
        <div class="candle-card" 
             data-title={candle.title.toLowerCase()}
             data-description={candle.description.toLowerCase()}
             data-tags={candle.tags.join(',').toLowerCase()}>
          
          <WorkCard 
            title={candle.title}
            description={candle.description}
            image={candle.image}
            href={candle.href}
          />
          
          <!-- タグ表示（サーバー側翻訳済み） -->
          <div class="flex flex-wrap gap-2 mt-4 px-1">
            {candle.translatedTags.map((tagObj) => (
              <span class="inline-block px-4 py-1 text-xs bg-[#4f6a5e]/10 text-[#4f6a5e] rounded-full font-medium">
                #{tagObj.label}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</div>

<script>
  // ====================== クライアントサイド処理（大幅に簡素化） ======================
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const searchForm = document.getElementById('search-form');
  const tagFiltersContainer = document.getElementById('tag-filters');
  const clearButton = document.getElementById('clear-filters');
  const candleCards = document.querySelectorAll('.candle-card');

  function filterCandles() {
    const query = searchInput.value.toLowerCase().trim();
    const activeTags = Array.from(tagFiltersContainer!.querySelectorAll('.tag-btn.active'))
                           .map(btn => (btn as HTMLElement).dataset.tag);

    candleCards.forEach(card => {
      const title = card.getAttribute('data-title') || '';
      const desc = card.getAttribute('data-description') || '';
      const cardTags = (card.getAttribute('data-tags') || '').split(',');

      const matchesSearch = !query || title.includes(query) || desc.includes(query);
      const matchesTags = activeTags.length === 0 || 
                         activeTags.every(tag => cardTags.includes(tag));

      (card as HTMLElement).style.display = (matchesSearch && matchesTags) ? 'block' : 'none';
    });
  }

  function initFilters() {
    // タグボタンのクリック処理
    tagFiltersContainer?.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target.classList.contains('tag-btn')) {
        target.classList.toggle('active');
        target.classList.toggle('border-[#4f6a5e]');
        target.classList.toggle('bg-[#4f6a5e]');
        target.classList.toggle('text-white');
        filterCandles();
      }
    });

    // 検索フォーム
    searchForm?.addEventListener('submit', (e) => {
      e.preventDefault();
      filterCandles();
      searchInput?.blur();
    });

    // クリアボタン
    clearButton?.addEventListener('click', () => {
      if (searchInput) searchInput.value = '';
      document.querySelectorAll('.tag-btn').forEach(btn => {
        btn.classList.remove('active', 'border-[#4f6a5e]', 'bg-[#4f6a5e]', 'text-white');
      });
      filterCandles();
    });
  }

  // 初期化
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initFilters);
  } else {
    initFilters();
  }
</script>

<style>
  .tag-btn.active {
    border-color: #4f6a5e;
    background-color: #4f6a5e;
    color: white;
  }
</style>