---
const newsItems = [
  {
    date: "2026.04.05",
    title: "新作ジオードキャンドル「アメジストの雫」発売開始",
    description: "深い紫色のグラデーションと本物のアメジストパウダーを使用した限定キャンドル。minneとEtsyにて販売中。",
    link: "https://minne.com/@tcc2024",
    tag: "新作"
  },
  {
    date: "2026.03.15",
    title: "Stockly 在庫管理アプリ β版をGitHubで公開",
    description: "キャンドル在庫と連動したシンプルな在庫管理ツール。オフライン対応とバーコードスキャン機能を搭載。",
    link: "#",
    tag: "アプリ"
  },
  {
    date: "2026.02.28",
    title: "ハンドメイドマルシェ出展のお知らせ",
    description: "2026年5月開催の札幌ハンドメイドマルシェへの出展が決定しました。詳細はイベントページをご覧ください。",
    link: "#events",
    tag: "イベント"
  },

];

function getTagClass(tag: string): string {
  if (tag === "新作") return "bg-[#4f6a5e] text-white";
  if (tag === "アプリ") return "bg-blue-600 text-white";
  if (tag === "イベント") return "bg-amber-500 text-white";
  return "bg-stone-100 text-stone-500";
}
---

<div id="news" class="section py-20 bg-[#f8f5f0]" data-island>
  <div class="max-w-screen-2xl mx-auto px-10">
    
    <!-- セクションタイトル -->
    <h2 class="text-5xl font-medium tracking-tight mb-12 text-stone-800">
      News
    </h2>

    <!-- ニュースカード一覧 -->
    <div class="grid md:grid-cols-3 gap-8">
      {newsItems.map((item) => (
        <a
          href={item.link}
          class="news-card block group"
          target={item.link.startsWith('http') ? '_blank' : '_self'}
          rel={item.link.startsWith('http') ? 'noopener noreferrer' : ''}
        >
          <div class="p-8 bg-white border border-stone-200 rounded-3xl 
                      hover:border-[#4f6a5e] hover:shadow-2xl hover:-translate-y-2 
                      transition-all duration-300 h-full flex flex-col">
            
            <!-- 日付とタグ -->
            <div class="flex items-center justify-between mb-6">
              <div class="text-xs text-stone-500 font-mono tracking-wider">
                {item.date}
              </div>
              <div class={`text-xs px-4 py-1.5 rounded-full font-medium ${getTagClass(item.tag)}`}>
                {item.tag}
              </div>
            </div>

            <!-- タイトル -->
            <h3 class="font-medium text-xl leading-tight group-hover:text-[#4f6a5e] transition-colors mb-4">
              {item.title}
            </h3>

            <!-- 説明文 -->
            <div class="text-stone-600 text-[15px] leading-relaxed flex-1">
              {item.description}
            </div>

          </div>
        </a>
      ))}
    </div>


  </div>
</div>

<!-- Island用クライアントスクリプト -->
<script>
  // ニュースカードクリック時の軽いフィードバック（EventsSectionと統一）
  document.querySelectorAll('.news-card').forEach((card) => {
    card.addEventListener('click', () => {
      card.style.transform = 'scale(0.97)';
      setTimeout(() => {
        card.style.transform = 'scale(1)';
      }, 180);
    });
  });

</script>