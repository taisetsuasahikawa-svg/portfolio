---
// src/components/NewsSection.astro
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { newsRaw } from '../data/news';
import CardHover from '../ui/CardHover.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// ニュースデータを現在の言語に変換
const newsItems = newsRaw.map(item => ({
  ...item,
  title: item.title[lang],
  description: item.description[lang],
}));

// 日付で新しい順（降順）に自動ソート
const sortedNewsItems = [...newsItems].sort((a, b) => {
  const dateToNum = (dateStr: string) => {
    const [y, m, d] = dateStr.split('.').map(Number);
    return y * 10000 + m * 100 + d;
  };
  return dateToNum(b.date) - dateToNum(a.date);
});

function getTagLabel(tag: string): string {
  const tagMap: Record<string, string> = {
    new:   t('newsTag.new'),
    app:   t('newsTag.app'),
    event: t('newsTag.event'),
    candle: t('newsTag.candle'),
    else:  t('newsTag.else'),
  };
  return tagMap[tag] || tag;
}

function getTagClass(tag: string): string {
  if (tag === 'new' || tag === 'candle') return "bg-[#4f6a5e] text-white";
  if (tag === 'app')                     return "bg-blue-600 text-white";
  if (tag === 'event')                   return "bg-amber-500 text-white";
  if (tag === 'else')                    return "bg-gray-500 text-white";
  return "bg-stone-100 text-stone-500";
}
---

<div id="news" class="section py-20 bg-[#f8f5f0]" data-island>
  <div class="max-w-screen-2xl mx-auto px-10">
    <h2 class="text-5xl font-medium tracking-tight mb-12 text-stone-800">
      {t('news.title')}
    </h2>

    <div class="grid md:grid-cols-3 gap-8">
      {sortedNewsItems.map((item) => (
        <CardHover 
          href={item.link}
          target={item.link.startsWith('http') ? '_blank' : '_self'}
          rel={item.link.startsWith('http') ? 'noopener noreferrer' : ''}
        >
          <div class="p-8 bg-white border border-stone-200 rounded-3xl 
                      hover:border-[#4f6a5e] hover:shadow-2xl h-full flex flex-col">
            
            <div class="flex items-center justify-between mb-6">
              <div class="text-xs text-stone-500 font-mono tracking-wider">
                {item.date}
              </div>
              
              <div class={`text-xs px-4 py-1.5 rounded-full font-medium ${getTagClass(item.tag)}`}>
                {getTagLabel(item.tag)}
              </div>
            </div>

            <h3 class="font-medium text-xl leading-tight group-hover:text-[#4f6a5e] transition-colors mb-4">
              {item.title}
            </h3>

            <div class="text-stone-600 text-[15px] leading-relaxed flex-1">
              {item.description}
            </div>
          </div>
        </CardHover>
      ))}
    </div>
  </div>
</div>