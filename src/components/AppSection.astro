---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { appsRaw, type AppRaw } from '../data/apps';
import { IMAGE_PATHS, CONTACT_INFO } from '../constants/paths';

const currentLang = getLangFromUrl(Astro.url);
const t = useTranslations(currentLang);

const apps = appsRaw.map((app: AppRaw) => ({
  ...app,
  title: app.title[currentLang],
  description: app.description[currentLang],
  statusLabel: t(`appStatus.${app.status}`),
  image: IMAGE_PATHS.apps[app.id] || `${import.meta.env.BASE_URL}images/apps/placeholder.jpg`,
}));

const gradients = [
  'from-emerald-700 via-teal-700 to-cyan-800',
  'from-amber-700 via-orange-700 to-red-800',
  'from-purple-700 via-violet-700 to-fuchsia-800',
  'from-rose-700 via-amber-700 to-yellow-800',
  'from-blue-700 via-indigo-700 to-violet-800',
  'from-lime-700 via-green-700 to-emerald-800',
];

function getAutoGradient(index: number): string {
  return gradients[index % gradients.length];
}

function getStatusClass(statusKey: string): string {
  if (statusKey === 'stable') return 'bg-emerald-600 text-white';
  if (statusKey === 'beta') return 'bg-amber-500 text-white';
  if (statusKey === 'inDevelopment') return 'bg-blue-600 text-white';
  if (statusKey === 'planning') return 'bg-stone-500 text-white';
  return 'bg-stone-500 text-white';
}
---

<div id="apps" class="section py-28 bg-white" data-island>
  <div class="max-w-screen-2xl mx-auto px-10">
    <div class="flex justify-between items-baseline mb-16">
      <h2 class="text-5xl font-medium tracking-tight text-stone-800">
        {t('app.section.title')}
      </h2>
      <a
        href={CONTACT_INFO.github}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 px-8 py-4 bg-white border-2 border-[#4f6a5e] rounded-3xl
               hover:bg-[#4f6a5e] hover:text-white hover:border-[#4f6a5e]
               transition-all duration-300 text-[#4f6a5e] font-medium text-lg shadow-sm"
      >
        {t('common.githubLink')}
      </a>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {apps.map((app, index) => (
        <div
          class="app-card group block bg-white border border-stone-200 rounded-3xl overflow-hidden
                 hover:border-[#4f6a5e] hover:shadow-2xl hover:-translate-y-2
                 transition-all duration-300"
        >
          <a
            href={app.github}
            target={app.github.startsWith('http') && app.github !== '#' ? '_blank' : '_self'}
            class="block"
          >
            <div class="relative h-52 overflow-hidden">
              <img
                src={app.image}
                alt={app.title}
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
              />

              <div class={`absolute inset-0 hidden flex-col items-center justify-center bg-gradient-to-br ${getAutoGradient(index)}`}>
                <div class="text-white/90 text-center px-8">
                  <div class="text-2xl font-medium tracking-tight mb-1">{app.title}</div>
                  <div class="text-xs opacity-75 tracking-widest">{app.platform}</div>
                </div>
              </div>

              <span class="absolute top-4 left-4 px-4 py-1 text-xs font-medium bg-white/90 text-stone-800 rounded-3xl shadow-sm z-10">
                {app.platform}
              </span>

              <span class={`absolute top-4 right-4 px-4 py-1 text-xs font-medium rounded-3xl shadow-sm z-10 ${getStatusClass(app.status)}`}>
                {app.statusLabel}
              </span>
            </div>

            <div class="p-8">
              <h3 class="text-2xl font-medium text-stone-900 group-hover:text-[#4f6a5e] transition-colors mb-2">
                {app.title}
              </h3>
              <p class="text-stone-600 leading-relaxed text-[15px]">
                {app.description}
              </p>

              <div class="flex flex-wrap gap-2 mt-6">
                {app.tags.map((tag) => (
                  <span class="text-xs px-3 py-1 bg-[#4f6a5e]/10 text-[#4f6a5e] rounded-3xl font-medium">
                    #{tag}
                  </span>
                ))}
              </div>
            </div>
          </a>
        </div>
      ))}
    </div>
  </div>
</div>
