---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<div id="apps" class="section py-28 bg-white" data-island>
  <div class="max-w-screen-2xl mx-auto px-10">
    <div class="flex justify-between items-baseline mb-16">
      <h2 class="text-5xl font-medium tracking-tight text-stone-800">
        {t('section.apps')}
      </h2>
      <a href="https://github.com/taisetsuasahikawa-svg" 
         target="_blank" 
         class="text-[#4f6a5e] hover:underline text-lg inline-flex items-center gap-2">
        GitHub →
      </a>
    </div>
    
    <div class="grid md:grid-cols-12 gap-12 items-center">
      <div class="md:col-span-5">
        <div class="bg-stone-900 text-white p-10 rounded-3xl hover:scale-[1.02] transition-transform cursor-pointer" id="app-card">
          <div class="flex justify-between mb-6">
            <span class="px-4 py-1 text-xs bg-white/10 rounded-3xl">Android / Kotlin</span>
            <span class="text-4xl">📦</span>
          </div>
          <h3 class="text-4xl font-medium">Stockly - 在庫管理アプリ</h3>
          <p class="mt-6 text-stone-300">
            {lang === 'en' 
              ? "Simple inventory management tool for small businesses. Supports barcode scanning, automatic notifications, and offline mode."
              : "小規模事業者向けシンプル在庫管理ツール。バーコードスキャン、自動通知、オフライン対応。"}
          </p>
        </div>
      </div>
      
      <div class="md:col-span-7">
        <p class="text-stone-600 text-lg max-w-lg mb-6">
          {lang === 'en' ? "Development / Planning Projects" : "開発中・構想中プロジェクト"}
        </p>
        <div id="features-list" class="space-y-3">
          <div class="px-5 py-4 bg-white border border-dashed rounded-3xl text-sm cursor-pointer hover:border-[#4f6a5e]">
            {lang === 'en' ? "Candle stock linkage management system" : "キャンドル在庫連動管理システム"}
          </div>
          <div class="px-5 py-4 bg-white border border-dashed rounded-3xl text-sm cursor-pointer hover:border-[#4f6a5e]">
            {lang === 'en' ? "Etsy automatic listing tool" : "Etsy自動出品ツール"}
          </div>
          <div class="px-5 py-4 bg-white border border-dashed rounded-3xl text-sm cursor-pointer hover:border-[#4f6a5e]">
            {lang === 'en' ? "Scent recipe management app" : "香りレシピ管理アプリ"}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  const card = document.getElementById('app-card');
  if (card) {
    card.addEventListener('click', () => {
      card.style.transform = 'scale(1.05)';
      setTimeout(() => card.style.transform = 'scale(1.02)', 200);
    });
  }
</script>