---
// src/components/MaterialsSection.astro
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const currentLang = getLangFromUrl(Astro.url);
const t = useTranslations(currentLang);
---

<div id="materials" class="section py-28 bg-white" data-island>
  <div class="max-w-screen-2xl mx-auto px-10 text-center">
    <div class="max-w-md mx-auto">
      
      <!-- SHOP バッジ -->
      <span class="uppercase text-xs tracking-widest text-stone-400">
        {t('common.shop')}
      </span>
      
      <!-- セクションタイトル -->
      <h2 class="text-5xl font-medium mt-3 tracking-tight text-stone-800">
        {t('materials.section.title')}
      </h2>
      
      <!-- 説明文 -->
      <p class="mt-6 text-stone-600">
        {t('materials.section.description')}
      </p>
      
      <!-- ショップボタン -->
      <div class="flex justify-center gap-6 mt-12">
        <a 
          href="https://mercari-shops.com/shops/JXp9LskbtDh3UE42i6DQdJ/" 
          target="_blank"
          class="materials-btn group flex-1 max-w-[280px] py-7 px-10 
                 bg-white border-2 border-stone-400 rounded-3xl 
                 hover:border-[#4f6a5e] hover:bg-[#f8f5f0] hover:shadow-xl hover:-translate-y-1 
                 transition-all duration-300 text-lg font-medium text-stone-800
                 active:scale-[0.97]">
          {t('materials.shop.mercari')}
        </a>
      </div>
    </div>
  </div>
</div>
