<div id="materials" class="section py-28 bg-white" data-island>
  <div class="max-w-screen-2xl mx-auto px-10 text-center">
    <div class="max-w-md mx-auto">
      <span class="uppercase text-xs tracking-widest text-stone-400">SHOP</span>
