                 bg-white border-2 border-stone-400 rounded-3xl 
                 hover:border-[#4f6a5e] hover:bg-[#f8f5f0] hover:shadow-xl hover:-translate-y-1 
                 transition-all duration-300 text-lg font-medium text-stone-800
                 active:scale-[0.97]">
          メルカリShops
        </a>
      </div>
    </div>
  </div>
