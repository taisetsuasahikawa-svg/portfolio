---
// src/components/EventsSection.astro
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { eventsRaw } from '../data/events';
import CardHover from '../ui/CardHover.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// 作品データを現在の言語に変換
const events = eventsRaw.map(item => ({
  ...item,
  title: item.title[lang],
  description: item.description[lang],
}));

// ====================== イベント用ヘルパー関数 ======================
function getEventStatus(startDate: string, endDate: string): string {
  const today = new Date();
  const start = new Date(startDate.replace(/\./g, '-'));
  const end = new Date(endDate.replace(/\./g, '-'));

  if (today > end) return t('eventStatus.ended');
  if (today < start) return t('eventStatus.upcoming');
  return t('eventStatus.ongoing');
}

function formatDateRange(startDate: string, endDate: string): string {
  // 同じ月の場合は「2025.05.24-25」のように短縮表示
  const [y1, m1] = startDate.split('.');
  const [y2, m2] = endDate.split('.');
  
  if (y1 === y2 && m1 === m2) {
    const d1 = startDate.split('.')[2];
    const d2 = endDate.split('.')[2];
    return `${y1}.${m1}.${d1}-${d2}`;
  }
  return `${startDate} - ${endDate}`;
}

function getStatusClass(status: string): string {
  if (status === t('eventStatus.ended'))    return "bg-stone-500 text-white";
  if (status === t('eventStatus.upcoming')) return "bg-amber-500 text-white";
  if (status === t('eventStatus.ongoing'))  return "bg-emerald-600 text-white";
  return "bg-stone-500 text-white";
}

// 日付で新しい順（降順）に自動ソート
const sortedEvents = [...events].sort((a, b) => {
  const dateToNum = (dateStr: string) => {
    const [y, m, d] = dateStr.split('.').map(Number);
    return y * 10000 + m * 100 + d;
  };
  return dateToNum(b.startDate) - dateToNum(a.startDate);
});
---

<div id="events" class="section py-20 bg-[#f8f5f0]" data-island>
  <div class="max-w-screen-2xl mx-auto px-10">
    <h2 class="text-5xl font-medium tracking-tight mb-12 text-stone-800">
      {t('events.title')}
    </h2>

    <div class="grid md:grid-cols-3 gap-8">
      {sortedEvents.map((event) => {
        const status = getEventStatus(event.startDate, event.endDate);
        const displayDate = formatDateRange(event.startDate, event.endDate);

        return (
          <CardHover 
            href={event.url}
            target={event.url.startsWith('http') ? '_blank' : '_self'}
            rel={event.url.startsWith('http') ? 'noopener noreferrer' : ''}
          >
            <div class="p-8 bg-white border border-stone-200 rounded-3xl 
                        hover:border-[#4f6a5e] hover:shadow-2xl h-full flex flex-col">
              
              <div class="flex items-center justify-between mb-6">
                <div class={`text-xs px-4 py-1.5 rounded-full font-medium ${getStatusClass(status)}`}>
                  {status}
                </div>
                <div class="text-xs text-stone-500 font-mono tracking-wider">
                  {displayDate}
                </div>
              </div>

              <h3 class="font-medium text-xl leading-tight group-hover:text-[#4f6a5e] transition-colors">
                {event.title}
              </h3>

              <div class="text-stone-600 text-[15px] leading-relaxed flex-1 space-y-2 mt-4">
                {event.description.map((line, i) => (
                  <p key={i}>{line}</p>
                ))}
              </div>
            </div>
          </CardHover>
        );
      })}
    </div>
  </div>
</div>