---
// src/ui/CandleCard.astro
// 最終改善版：全体クリック可能 + ImageSlider のスライド操作を完全に保護

import ImageSlider from './ImageSlider.astro';
import { useTranslations } from '../i18n/utils';

interface Props {
  candle: {
    title: string;
    description: string;
    burnTime?: string;
    size?: string;
    images?: any[];
    image?: string;
    tags?: string[];
    slug?: string;
    [key: string]: any;
  };
  lang: string;
  href: string;

  // フィルター用（candles/index.astro）
  dataTitle?: string;
  dataDescription?: string;
  dataTags?: string;
}

const { 
  candle, 
  lang, 
  href, 
  dataTitle, 
  dataDescription, 
  dataTags 
} = Astro.props;

const t = useTranslations(lang);

// ImageSlider 用に画像を正規化
const imagesForSlider = candle.images?.length 
  ? candle.images 
  : candle.image 
    ? [{ path: candle.image, alt: { [lang]: candle.title } }] 
    : [];
---

<div 
  class="candle-card group relative bg-white border border-stone-200 rounded-3xl overflow-hidden 
         hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 cursor-pointer"
  data-title={dataTitle || candle.title.toLowerCase()}
  data-description={dataDescription || candle.description.toLowerCase()}
  data-tags={(dataTags || candle.tags?.join(','))?.toLowerCase() || ''}
  onclick={`if (!event.target.closest('.splide, .splide__arrow, .splide__pagination')) { window.location.href = '${href}'; }`}
>
  <!-- ① 画像エリア -->
  <div class="p-4 relative">
    <!-- pointer-events-auto でスライダー操作を保護 -->
    <div class="pointer-events-auto">
      <ImageSlider 
        images={imagesForSlider} 
        title={{ [lang]: candle.title }} 
        lang={lang} 
      />
    </div>
  </div>

  <!-- ② 情報エリア -->
  <!-- スライダー部分は onclick 条件で除外される -->
  <div class="px-8 pb-8 pt-2 pointer-events-auto">
    <h3 class="text-2xl font-medium text-stone-900 group-hover:text-[#4f6a5e] transition-colors mb-4 line-clamp-2">
      {candle.title}
    </h3>
    
    <p class="text-stone-600 leading-relaxed mb-8 line-clamp-4">
      {candle.description}
    </p>

    <!-- スペック -->
    <div class="grid grid-cols-2 gap-x-8 text-sm border-t border-stone-100 pt-6">
      {candle.burnTime && (
        <div>
          <span class="block text-stone-500 text-xs tracking-widest">
            {t('candle.detail.burnTime') || '燃焼時間'}
          </span>
          <span class="font-medium text-base">{candle.burnTime}</span>
        </div>
      )}
      {candle.size && (
        <div>
          <span class="block text-stone-500 text-xs tracking-widest">
            {t('candle.detail.size') || 'サイズ'}
          </span>
          <span class="font-medium text-base">{candle.size}</span>
        </div>
      )}
    </div>

    <!-- タグ -->
    {candle.tags && candle.tags.length > 0 && (
      <div class="flex flex-wrap gap-2 mt-8">
        {candle.tags.map((tag: string) => (
          <span 
            class="inline-block px-4 py-1 text-xs bg-[#4f6a5e]/10 text-[#4f6a5e] 
                   rounded-3xl font-medium tracking-wide"
          >
            #{t(`candleTag.${tag}`) || tag}
          </span>
        ))}
      </div>
    )}
  </div>
</div>

<!-- 追加スタイル（視覚的な強調） -->
<style>
  .candle-card {
    transition: all 0.3s cubic-bezier(0.4, 0.0, 0.2, 1);
  }
  
  .candle-card:hover {
    box-shadow: 0 25px 50px -12px rgb(0 0 0 / 0.15);
  }

  .candle-card:active {
    transform: scale(0.985);
  }


  .splide__arrow,
  .splide__pagination__page {
    pointer-events: auto;
  }
</style>