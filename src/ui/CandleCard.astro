---
import ImageSlider from './ImageSlider.astro';
import TagPill from './TagPill.astro';
import { useTranslations } from '../i18n/utils';
import type { ProcessedCandle } from '../lib/GetCandleContents.ts';
import type { Lang } from '../i18n/ui.ts';

interface Props {
  candle: ProcessedCandle;
  lang: Lang;
  href: string;
  filterTitle?: string;
  filterDescription?: string;
  filterTags?: string;
}

const {
  candle,
  lang,
  href,
  filterTitle,
  filterDescription,
  filterTags,
} = Astro.props;

const t = useTranslations(lang);

const sliderImages = candle.images?.length
  ? candle.images
  : candle.image
    ? [{ path: candle.image, alt: { [lang]: candle.title } }]
    : [];
---

<div
  class="candle-card group relative bg-white border border-stone-200 rounded-3xl overflow-hidden hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 cursor-pointer"
  data-title={filterTitle || candle.title.toLowerCase()}
  data-description={filterDescription || candle.description.toLowerCase()}
  data-tags={(filterTags || candle.tags?.join(','))?.toLowerCase() || ''}
  onclick={`if (!event.target.closest('.splide, .splide__arrow, .splide__pagination')) { window.location.href = '${href}'; }`}
>
  <div class="p-4 relative">
    <div class="pointer-events-auto">
      <ImageSlider
        images={sliderImages}
        title={{ [lang]: candle.title }}
        lang={lang}
      />
    </div>
  </div>

  <div class="px-8 pb-8 pt-2 pointer-events-auto">
    <h3 class="text-2xl font-medium text-stone-900 group-hover:text-[#4f6a5e] transition-colors mb-4 line-clamp-2">
      {candle.title}
    </h3>

    <p class="text-stone-600 leading-relaxed mb-8 line-clamp-4">
      {candle.description}
    </p>

    <div class="grid grid-cols-2 gap-x-8 text-sm border-t border-stone-100 pt-6">
      {candle.burnTime && (
        <div>
          <span class="block text-stone-500 text-xs tracking-widest">
            {t('candle.detail.burnTime') || '燃焼時間'}
          </span>
          <span class="font-medium text-base">{candle.burnTime}</span>
        </div>
      )}
      {candle.size && (
        <div>
          <span class="block text-stone-500 text-xs tracking-widest">
            {t('candle.detail.size') || 'サイズ'}
          </span>
          <span class="font-medium text-base">{candle.size}</span>
        </div>
      )}
    </div>

    {candle.tags && candle.tags.length > 0 && (
      <div class="flex flex-wrap gap-2 mt-8">
        {candle.tags.map((tag: string) => (
          <TagPill tag={tag} lang={lang} />
        ))}
      </div>
    )}
  </div>
</div>

<style>
  .candle-card {
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .candle-card:hover {
    box-shadow: 0 25px 50px -12px rgb(0 0 0 / 0.15);
  }

  .candle-card:active {
    transform: scale(0.985);
  }

  .splide__arrow,
  .splide__pagination__page {
    pointer-events: auto;
  }
</style>
