---
// src/ui/WorkCard.astro
--- 
<div class="work-card group block" data-island>
  <a href={Astro.props.href} class="block">
    <div class="relative overflow-hidden rounded-3xl">
      <img 
        src={Astro.props.image} 
        alt={Astro.props.title}
        class="w-full aspect-[4/3] object-cover transition-transform duration-700 group-hover:scale-105"
      />
      
      <!-- VIEWオーバーレイ -->
      <div class="work-overlay absolute inset-0 bg-gradient-to-t from-[#4f6a5e]/90 via-[#4f6a5e]/30 to-transparent flex items-end justify-center pb-8 opacity-0 group-hover:opacity-100 transition-all duration-500">
        <div class="view-text text-white text-xl font-semibold tracking-[3px] translate-y-8 group-hover:translate-y-0 transition-all duration-500">
          VIEW
        </div>
      </div>
    </div>
    
    <div class="pt-6 px-1">
      <h3 class="text-2xl font-medium">{Astro.props.title}</h3>
      <p class="text-stone-600 mt-2 line-clamp-3">{Astro.props.description}</p>
    </div>
  </a>
</div>

<style>
  .work-card {
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .work-card:hover {
    transform: translateY(-6px);
  }
  .work-overlay {
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .view-text {
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }
</style>
